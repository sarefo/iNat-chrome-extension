{
  "manifest_version": 3,
  "name": "iNaturalist Auto Filler",
  "version": "1.0",
  "description": "Auto-fills common iNaturalist observation fields",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://api.inaturalist.org/*", "*://*.inaturalist.org/*"],
  "background": {
    "service_worker": "background/background-main.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fill iNaturalist Fields",
    "default_icon": "iNat-favicon.png"
  },
  "content_scripts": [{
    "matches": ["*://*.inaturalist.org/*"],
    "js": [
      "content/bulk-storage.js",
      "content/bulk-state.js",
      "content/bulk-selection.js",
      "content/bulk-processing.js",
      "content/bulk-ui.js",
      "content/content-main.js"
    ]
  }],
  "web_accessible_resources": [{
    "resources": [
      "content/bulk-storage.js",
      "content/bulk-state.js",
      "content/bulk-selection.js",
      "content/bulk-processing.js",
      "content/bulk-ui.js",
      "content/content-main.js"
    ],
    "matches": ["*://*.inaturalist.org/*"]
  }]
}
